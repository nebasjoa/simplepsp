              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test(\"409 Conflict\", () => pm.response.to.have.status(409));"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Gateway API - Auth Failure Demos",
      "description": "Each request deliberately breaks one part of the signature scheme to show the corresponding rejection. No folder-level signing here - each request builds its own (broken) headers.",
      "item": [
        {
          "name": "401 - Missing API Key",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/v1/payments/{{paymentId}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "v1", "payments", "{{paymentId}}"]
            },
            "description": "No X-Api-Key header at all."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test(\"401 Unauthorized\", () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "401 - Invalid Signature",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Math.floor(Date.now() / 1000);",
                  "pm.request.headers.upsert({ key: \"X-Api-Key\", value: pm.collectionVariables.get(\"apiKey\") });",
                  "pm.request.headers.upsert({ key: \"X-Timestamp\", value: String(timestamp) });",
                  "pm.request.headers.upsert({ key: \"X-Signature\", value: \"0\".repeat(64) });"
                ]
              }
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test(\"401 Unauthorized\", () => pm.response.to.have.status(401));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/v1/payments/{{paymentId}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "v1", "payments", "{{paymentId}}"]
            },
            "description": "Valid api key + timestamp, but a bogus (all-zero) signature."
          }
        },
        {
          "name": "401 - Expired Timestamp",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const secret = pm.collectionVariables.get(\"apiSecret\");",
                  "const apiKey = pm.collectionVariables.get(\"apiKey\");",
                  "const staleTimestamp = Math.floor(Date.now() / 1000) - 400;",
                  "const rawBody = \"\";",
                  "const signature = CryptoJS.HmacSHA256(`${staleTimestamp}.${rawBody}`, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: \"X-Api-Key\", value: apiKey });",
                  "pm.request.headers.upsert({ key: \"X-Timestamp\", value: String(staleTimestamp) });",
                  "pm.request.headers.upsert({ key: \"X-Signature\", value: signature });"
                ]
              }
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test(\"401 Unauthorized\", () => pm.response.to.have.status(401));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/v1/payments/{{paymentId}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "v1", "payments", "{{paymentId}}"]
            },
            "description": "Correctly signed, but the timestamp is 400 seconds old - past the 300s replay-protection window."
          }
        }
      ]
    },
