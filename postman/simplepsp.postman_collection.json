  "item": [
    {
      "name": "Gateway API (HMAC signed)",
      "description": "Every request here is signed automatically: X-Api-Key, X-Timestamp, and X-Signature are computed by the folder's pre-request script over `${timestamp}.${rawBody}` using apiSecret, exactly matching packages/shared/src/hmac.ts.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const secret = pm.collectionVariables.get(\"apiSecret\");",
              "const apiKey = pm.collectionVariables.get(\"apiKey\");",
              "const timestamp = Math.floor(Date.now() / 1000);",
              "",
              "let rawBody = \"\";",
              "if (pm.request.body && pm.request.body.mode === \"raw\" && pm.request.body.raw) {",
              "  rawBody = pm.variables.replaceIn(pm.request.body.raw);",
              "}",
              "",
              "const signature = CryptoJS.HmacSHA256(`${timestamp}.${rawBody}`, secret).toString(CryptoJS.enc.Hex);",
              "",
              "pm.request.headers.upsert({ key: \"X-Api-Key\", value: apiKey });",
              "pm.request.headers.upsert({ key: \"X-Timestamp\", value: String(timestamp) });",
              "pm.request.headers.upsert({ key: \"X-Signature\", value: signature });"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "Create Payment - Hosted",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1099,\n  \"currency\": \"EUR\",\n  \"reference\": \"postman_hosted_{{$timestamp}}\",\n  \"captureNow\": true,\n  \"returnUrl\": \"https://example.com/return\",\n  \"webhookUrl\": \"https://example.com/webhook\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayUrl}}/api/v1/payments", "host": ["{{gatewayUrl}}"], "path": ["api", "v1", "payments"] },
            "description": "No `card` in the body -> the gateway returns a `redirectUrl` to its hosted payment form instead of a final status."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"201 Created\", () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test(\"has redirectUrl\", () => pm.expect(json.redirectUrl).to.be.a(\"string\"));",
                  "pm.collectionVariables.set(\"paymentId\", json.id);"
                ]
              }
            }
          ]
        },
        {
