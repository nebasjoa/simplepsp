            "url": {
              "raw": "{{portalUrl}}/api/portal/test-payment",
              "host": ["{{portalUrl}}"],
              "path": ["api", "portal", "test-payment"]
            },
            "description": "Signs a real request to the gateway using this merchant's own stored credentials - returns a redirectUrl to the hosted form."
          }
        },
        {
          "name": "Fire Test Payment (Direct)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"direct\",\n  \"cardNumber\": \"4242424242424242\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{portalUrl}}/api/portal/test-payment",
              "host": ["{{portalUrl}}"],
              "path": ["api", "portal", "test-payment"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin (Operator Session)",
      "description": "Separate session namespace from the merchant portal - an operator session cannot call /api/portal/* and vice versa. Run \"Operator Login\" first (set `operatorPassword` from your `pnpm db:seed` output).",
      "item": [
        {
          "name": "Operator Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{operatorEmail}}\",\n  \"password\": \"{{operatorPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{portalUrl}}/api/admin/login", "host": ["{{portalUrl}}"], "path": ["api", "admin", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test(\"200 OK\", () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "List Merchants",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{portalUrl}}/api/admin/merchants", "host": ["{{portalUrl}}"], "path": ["api", "admin", "merchants"] }
          }
        },
        {
          "name": "Create Merchant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Merchant\",\n  \"email\": \"postman-{{$timestamp}}@demo.test\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{portalUrl}}/api/admin/merchants", "host": ["{{portalUrl}}"], "path": ["api", "admin", "merchants"] },
            "description": "apiKey, secret, and the initial portal password are shown once - captured here into newMerchant* collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"201-ish (2xx) response\", () => pm.expect(pm.response.code).to.be.within(200, 201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"merchantId\", json.id);",
                  "pm.collectionVariables.set(\"newMerchantId\", json.id);",
                  "pm.collectionVariables.set(\"newMerchantApiKey\", json.apiKey);",
                  "pm.collectionVariables.set(\"newMerchantSecret\", json.secret);",
                  "pm.collectionVariables.set(\"newMerchantPassword\", json.initialPassword);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Merchant",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{portalUrl}}/api/admin/merchants/{{merchantId}}",
              "host": ["{{portalUrl}}"],
              "path": ["api", "admin", "merchants", "{{merchantId}}"]
            }
          }
        },
        {
          "name": "Disable Merchant",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"active\": false\n}", "options": { "raw": { "language": "json" } } },
            "url": {
              "raw": "{{portalUrl}}/api/admin/merchants/{{merchantId}}",
              "host": ["{{portalUrl}}"],
              "path": ["api", "admin", "merchants", "{{merchantId}}"]
            }
          }
        },
        {
          "name": "Enable Merchant",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"active\": true\n}", "options": { "raw": { "language": "json" } } },
            "url": {
              "raw": "{{portalUrl}}/api/admin/merchants/{{merchantId}}",
              "host": ["{{portalUrl}}"],
              "path": ["api", "admin", "merchants", "{{merchantId}}"]
            }
          }
        },
        {
          "name": "Rotate Merchant Secret",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{portalUrl}}/api/admin/merchants/{{merchantId}}/rotate-secret",
              "host": ["{{portalUrl}}"],
              "path": ["api", "admin", "merchants", "{{merchantId}}", "rotate-secret"]
            }
          }
        },
        {
          "name": "Reset Merchant Portal Password",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{portalUrl}}/api/admin/merchants/{{merchantId}}/reset-password",
              "host": ["{{portalUrl}}"],
              "path": ["api", "admin", "merchants", "{{merchantId}}", "reset-password"]
            }
          }
        }
      ]
    },
    {
