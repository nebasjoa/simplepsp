              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayUrl}}/api/v1/payments", "host": ["{{gatewayUrl}}"], "path": ["api", "v1", "payments"] },
            "description": "Card present -> direct (server-to-server) flow. The acquirer approves this test card synchronously and the response already carries the final status."
          },
          "event": [
