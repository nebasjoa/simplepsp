        {
          "name": "Idempotency - Create (1st send)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 750,\n  \"currency\": \"EUR\",\n  \"reference\": \"postman_idempotency_demo\",\n  \"captureNow\": true,\n  \"returnUrl\": \"https://example.com/return\",\n  \"webhookUrl\": \"https://example.com/webhook\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayUrl}}/api/v1/payments", "host": ["{{gatewayUrl}}"], "path": ["api", "v1", "payments"] },
            "description": "Send this twice in a row (unchanged) - the second send returns the exact same payment id instead of creating a duplicate. Then try \"Idempotency - Conflict\" to see the 409 case."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"201 Created\", () => pm.response.to.have.status(201));",
                  "const previous = pm.collectionVariables.get(\"lastIdempotentId\");",
                  "const current = pm.response.json().id;",
                  "if (previous) {",
                  "  pm.test(\"replay returns the same payment id\", () => pm.expect(current).to.eql(previous));",
                  "}",
                  "pm.collectionVariables.set(\"lastIdempotentId\", current);"
                ]
              }
            }
          ]
        },
        {
          "name": "Idempotency - Conflict (different body, same key)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 999,\n  \"currency\": \"EUR\",\n  \"reference\": \"postman_idempotency_demo\",\n  \"captureNow\": true,\n  \"returnUrl\": \"https://example.com/return\",\n  \"webhookUrl\": \"https://example.com/webhook\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayUrl}}/api/v1/payments", "host": ["{{gatewayUrl}}"], "path": ["api", "v1", "payments"] },
            "description": "Same Idempotency-Key as the request above, but a different `amount` -> the gateway must refuse to guess which body was intended."
