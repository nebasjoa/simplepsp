{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @simplepsp/acquirer... run build --if-present"
  },
  "deploy": {
    "startCommand": "pnpm --filter @simplepsp/acquirer start",
    "restartPolicyType": "ON_FAILURE"
  }
}
